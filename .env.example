# ──────────────────────────────────────────────
# chat-multi-stream — environment configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────

# HTTP server port
SERVER_PORT=8080

# ── Twitch ─────────────────────────────────────
# Anonymous read-only listener — no token required.
# Channel name as it appears in twitch.tv/<channel> (lowercase).
# Works even when the streamer is offline (IRC channel always exists).
TWITCH_CHANNEL=channelname

# ── YouTube ────────────────────────────────────
# Requires a YouTube Data API v3 key (free tier: 10 000 quota units/day).
# Channel handle with or without the '@' prefix.
# The server auto-discovers the active live stream and waits (checking
# every 60 s) if the channel is currently offline.
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL=@channelHandle

# ── Kick ───────────────────────────────────────
# Channel name as it appears in kick.com/<channel>.
# Chatroom ID is resolved automatically at startup.
# Kick chatrooms exist regardless of live status.
KICK_CHANNEL=channelname
